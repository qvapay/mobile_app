# sonner-native@0.25.1 (latest) still declares peer ranges for the older
# react-native-gesture-handler (^2.28) and react-native-worklets (^0.8), which
# conflict with the upgraded gesture-handler@3 / reanimated@4.4 + worklets@0.9.
# The runtime APIs remain compatible (GH builder API is backward compatible and
# the worklets bump is minor), so we relax peer resolution until sonner-native
# widens its peer ranges. Remove this once sonner-native supports GH 3 / worklets 0.9.
legacy-peer-deps=true
