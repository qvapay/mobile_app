# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Use static frameworks to support Swift pods like VisionCamera and avoid non-modular includes
use_frameworks! :linkage => :static

target 'QvaPay' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :new_arch_enabled => false,
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Ensure a consistent Swift toolchain across all Pods
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['SWIFT_VERSION'] = '5.9'
        # Normalize REACT_NATIVE_PATH to an absolute path to avoid script resolution issues
        config.build_settings['REACT_NATIVE_PATH'] = File.join(Pod::Config.instance.installation_root, '..', 'node_modules', 'react-native')
        # Allow non-modular includes to prevent build errors with static frameworks
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end

    # Patch script phases that reference with-environment.sh to use absolute path
    absolute_rn_path = File.join(Pod::Config.instance.installation_root, '..', 'node_modules', 'react-native')
    with_env_abs = File.join(absolute_rn_path, 'scripts', 'xcode', 'with-environment.sh')
    installer.pods_project.targets.each do |target|
      target.build_phases.each do |phase|
        next unless phase.respond_to?(:shell_script) && phase.shell_script
        if phase.shell_script.include?('with-environment.sh')
          phase.shell_script = phase.shell_script
            .gsub('${REACT_NATIVE_PATH}/scripts/xcode/with-environment.sh', with_env_abs)
            .gsub('"$REACT_NATIVE_PATH/scripts/xcode/with-environment.sh"', '"' + with_env_abs + '"')
            .gsub("'$REACT_NATIVE_PATH/scripts/xcode/with-environment.sh'", "'" + with_env_abs + "'")
        end
      end
    end

  end
end
