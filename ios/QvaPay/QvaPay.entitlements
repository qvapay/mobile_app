<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>aps-environment</key>
	<string>development</string>
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:qvapay.com</string>
		<string>applinks:www.qvapay.com</string>
		<string>webcredentials:qvapay.com</string>
		<string>webcredentials:qvapay.com?mode=developer</string>
	</array>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.qvapay</string>
		<string>group.com.qvapay.app.onesignal</string>
	</array>
</dict>
</plist>
